```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
pip-tools/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
.coverage
coverage/
htmlcov/

# Python specific
*.pyo
*.pyd
.Python
*.so
*.egg-info/

# Distribution / packaging
dist/
build/
*.egg
*.tar.gz
*.whl
```